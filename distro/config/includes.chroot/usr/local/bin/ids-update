#!/bin/bash
# Cyjan IDS – Update-Script
# Zieht den aktuellen Stand von GitHub und baut geänderte Images neu.
set -euo pipefail

IDS_DIR="/opt/ids"
LOG="/var/log/cyjan/update.log"
CYJAN_STATE="/etc/cyjan"

echo "=== Cyjan IDS Update $(date) ===" | tee -a "$LOG"

# Proxy laden falls konfiguriert
[ -f /etc/environment ] && source /etc/environment || true

cd "$IDS_DIR"

# Aktuellen Commit merken
OLD_COMMIT=$(git rev-parse HEAD)

echo "[update] Git pull..."
git pull --ff-only origin main | tee -a "$LOG"

NEW_COMMIT=$(git rev-parse HEAD)

if [ "$OLD_COMMIT" = "$NEW_COMMIT" ]; then
  echo "[update] Keine Änderungen – Stack unverändert."
  exit 0
fi

echo "[update] Neue Commits: $(git log --oneline "${OLD_COMMIT}..${NEW_COMMIT}")"

# Selbst-Update: dieses Skript liegt in /usr/local/bin/, der Pull aktualisiert
# nur die Quelle in $IDS_DIR/distro/.... Vor allen weiteren Schritten kopieren
# wir uns selbst frisch raus und re-execen, sonst läuft die alte Version
# weiter und verpasst neue Patch-Logik (z.B. das System-Unit-Sync unten).
if [ -z "${IDS_UPDATE_RELOADED:-}" ]; then
  SRC="$IDS_DIR/distro/config/includes.chroot/usr/local/bin/ids-update"
  if [ -f "$SRC" ] && ! cmp -s "$SRC" "$0"; then
    echo "[update] Aktualisiere $0 aus $SRC und re-execen." | tee -a "$LOG"
    install -m 0755 "$SRC" "$0" 2>>"$LOG" || true
    export IDS_UPDATE_RELOADED=1
    exec "$0" "$@"
  fi
fi

# Profil laden – /etc/cyjan/profile speichert ggf. "prod,snort" als komma-
# separierten String. Compose interpretiert `--profile "a,b"` als einen
# einzigen Profilnamen, deshalb pro Profil ein eigenes --profile-Flag in
# einem Array sammeln.
PROFILE=$(cat "$CYJAN_STATE/profile" 2>/dev/null || echo "prod")
PROFILE_FLAGS=()
IFS=',' read -ra _profile_list <<< "$PROFILE"
for _p in "${_profile_list[@]}"; do
  [ -n "$_p" ] && PROFILE_FLAGS+=(--profile "$_p")
done

echo "[update] Baue geänderte Images..."
docker compose "${PROFILE_FLAGS[@]}" build | tee -a "$LOG"

echo "[update] Starte geänderte Dienste neu..."
docker compose "${PROFILE_FLAGS[@]}" up -d | tee -a "$LOG"

# Nachzügler-Sync: System-Dateien, die im ISO-Hook landen, kommen via reinem
# git-pull nicht an. Wir spiegeln idempotent die wenigen Stellen, deren
# Drift Reboot- oder Boot-Pfad bricht.
echo "[update] Synchronisiere System-Units aus distro/..." | tee -a "$LOG"

# cyjan-stack.service + Helper: idempotenter Compose-up beim Boot. Fehlt auf
# Maschinen, deren ISO älter ist als dieser Commit.
SRC_UNIT="$IDS_DIR/distro/config/includes.chroot/etc/systemd/system/cyjan-stack.service"
SRC_BIN="$IDS_DIR/distro/config/includes.chroot/usr/local/bin/cyjan-stack-up"
DST_UNIT="/etc/systemd/system/cyjan-stack.service"
DST_BIN="/usr/local/bin/cyjan-stack-up"
RELOAD_SYSTEMD=0

if [ -f "$SRC_UNIT" ] && ! cmp -s "$SRC_UNIT" "$DST_UNIT"; then
  install -m 0644 "$SRC_UNIT" "$DST_UNIT"
  RELOAD_SYSTEMD=1
  echo "[update]   $DST_UNIT aktualisiert" | tee -a "$LOG"
fi

if [ -f "$SRC_BIN" ] && ! cmp -s "$SRC_BIN" "$DST_BIN"; then
  install -m 0755 "$SRC_BIN" "$DST_BIN"
  echo "[update]   $DST_BIN aktualisiert" | tee -a "$LOG"
fi

if [ "$RELOAD_SYSTEMD" = "1" ]; then
  systemctl daemon-reload
fi

if [ -f "$DST_UNIT" ] && ! systemctl is-enabled --quiet cyjan-stack.service 2>/dev/null; then
  systemctl enable cyjan-stack.service 2>>"$LOG" && \
    echo "[update]   cyjan-stack.service aktiviert" | tee -a "$LOG"
fi

echo "[update] Update abgeschlossen $(date)" | tee -a "$LOG"
