#!/bin/bash
# Cyjan IDS – Update-Script
# Zieht den aktuellen Stand von GitHub und baut geänderte Images neu.
set -euo pipefail

IDS_DIR="/opt/ids"
LOG="/var/log/cyjan/update.log"
CYJAN_STATE="/etc/cyjan"

echo "=== Cyjan IDS Update $(date) ===" | tee -a "$LOG"

# Proxy laden falls konfiguriert
[ -f /etc/environment ] && source /etc/environment || true

cd "$IDS_DIR"

# Aktuellen Commit merken
OLD_COMMIT=$(git rev-parse HEAD)

echo "[update] Git pull..."
git pull --ff-only origin main | tee -a "$LOG"

NEW_COMMIT=$(git rev-parse HEAD)

if [ "$OLD_COMMIT" = "$NEW_COMMIT" ]; then
  echo "[update] Keine Änderungen – Stack unverändert."
  exit 0
fi

echo "[update] Neue Commits: $(git log --oneline "${OLD_COMMIT}..${NEW_COMMIT}")"

# Selbst-Update: dieses Skript liegt in /usr/local/bin/, der Pull aktualisiert
# nur die Quelle in $IDS_DIR/distro/.... Vor allen weiteren Schritten kopieren
# wir uns selbst frisch raus und re-execen, sonst läuft die alte Version
# weiter und verpasst neue Patch-Logik (z.B. das System-Unit-Sync unten).
if [ -z "${IDS_UPDATE_RELOADED:-}" ]; then
  SRC="$IDS_DIR/distro/config/includes.chroot/usr/local/bin/ids-update"
  if [ -f "$SRC" ] && ! cmp -s "$SRC" "$0"; then
    echo "[update] Aktualisiere $0 aus $SRC und re-execen." | tee -a "$LOG"
    install -m 0755 "$SRC" "$0" 2>>"$LOG" || true
    export IDS_UPDATE_RELOADED=1
    exec "$0" "$@"
  fi
fi

# Mode + Profil laden — gleiche Logik wie cyjan-stack-up:
#   /etc/cyjan/mode  (optional, Default 'master')
#     master → docker-compose.yml mit --profile aus /etc/cyjan/profile
#     tap    → docker-compose.tap.yml (kein --profile, schmaler Stack)
# Tap-Hosts haben kein MIRROR_IFACE in der .env (kommt aus /etc/cyjan/profile),
# nutzen aber eine eigene Compose-Datei. Ohne -f -Flag würde docker compose
# die Master-docker-compose.yml laden und mit "MIRROR_IFACE missing" abbrechen.
MODE=$(cat "$CYJAN_STATE/mode" 2>/dev/null | tr -d '[:space:]')
[ -z "$MODE" ] && MODE="master"

COMPOSE_ARGS=()
PROFILE_FLAGS=()
case "$MODE" in
  tap)
    COMPOSE_ARGS=(-f docker-compose.tap.yml)
    ;;
  master|*)
    PROFILE=$(cat "$CYJAN_STATE/profile" 2>/dev/null || echo "prod")
    IFS=',' read -ra _profile_list <<< "$PROFILE"
    for _p in "${_profile_list[@]}"; do
      [ -n "$_p" ] && PROFILE_FLAGS+=(--profile "$_p")
    done
    ;;
esac

echo "[update] Mode=$MODE  Compose=${COMPOSE_ARGS[*]:-default}  Profile=${PROFILE_FLAGS[*]:-none}" | tee -a "$LOG"

echo "[update] Baue geänderte Images..."
docker compose "${COMPOSE_ARGS[@]}" "${PROFILE_FLAGS[@]}" build | tee -a "$LOG"

echo "[update] Starte geänderte Dienste neu..."
docker compose "${COMPOSE_ARGS[@]}" "${PROFILE_FLAGS[@]}" up -d | tee -a "$LOG"

# Nachzügler-Sync: System-Dateien, die im ISO-Hook landen, kommen via reinem
# git-pull nicht an. Wir spiegeln idempotent die Stellen, deren Drift
# Reboot-/Boot-/Login-Pfad bricht — alles darüber hinaus bleibt absichtlich
# Sache des nächsten ISO-Builds (Wizard, Installer etc. updaten sich selbst
# bzw. sind Frischinstall-Pfad).
echo "[update] Synchronisiere System-Dateien aus distro/..." | tee -a "$LOG"

DISTRO_DIR="$IDS_DIR/distro/config/includes.chroot"
RELOAD_SYSTEMD=0

# _sync_file <src-rel-zu-DISTRO_DIR> <dst-abs> <mode> [systemd]
# Idempotent: cmp gleicher Inhalt → kein Schreib, kein Log-Eintrag.
_sync_file() {
  local src="$DISTRO_DIR/$1"
  local dst="$2"
  local mode="$3"
  local needs_reload="${4:-}"

  [ -f "$src" ] || return 0
  if cmp -s "$src" "$dst" 2>/dev/null; then
    return 0
  fi
  install -m "$mode" -D "$src" "$dst" 2>>"$LOG" || return 0
  echo "[update]   $dst aktualisiert" | tee -a "$LOG"
  if [ "$needs_reload" = "systemd" ]; then
    RELOAD_SYSTEMD=1
  fi
}

# Login-Banner (Master- und Tap-Mode-bewusst)
_sync_file "etc/profile.d/ids-banner.sh" \
           "/etc/profile.d/ids-banner.sh" 0755

# Idempotenter Compose-up beim Boot
_sync_file "etc/systemd/system/cyjan-stack.service" \
           "/etc/systemd/system/cyjan-stack.service" 0644 systemd
_sync_file "usr/local/bin/cyjan-stack-up" \
           "/usr/local/bin/cyjan-stack-up" 0755

# Tap-CLI (auf Master-Hosts unschädlich, ruft tap-api auf 127.0.0.1:8001 das
# nicht läuft → Fehlermeldung im Aufruf, kein Boot-Impact)
_sync_file "usr/local/bin/cyjan-tap" \
           "/usr/local/bin/cyjan-tap" 0755

# Boot-Status-Anzeige (TTY1)
_sync_file "usr/local/bin/cyjan-bootstatus" \
           "/usr/local/bin/cyjan-bootstatus" 0755
_sync_file "etc/systemd/system/cyjan-bootstatus.service" \
           "/etc/systemd/system/cyjan-bootstatus.service" 0644 systemd

if [ "$RELOAD_SYSTEMD" = "1" ]; then
  systemctl daemon-reload
fi

# Auto-Enable nur wenn frisch installiert (idempotent — erneutes enable ist
# no-op).
if [ -f "/etc/systemd/system/cyjan-stack.service" ] && ! systemctl is-enabled --quiet cyjan-stack.service 2>/dev/null; then
  systemctl enable cyjan-stack.service 2>>"$LOG" && \
    echo "[update]   cyjan-stack.service aktiviert" | tee -a "$LOG"
fi

echo "[update] Update abgeschlossen $(date)" | tee -a "$LOG"
