#!/usr/bin/env bash
# Cyjan IDS – Master-Console-Updater.
#
# Holt das aktuelle (oder ein bestimmtes) Update-ZIP aus dem GitHub-Release,
# lädt die Images via docker load und recreatet den Stack — alles ohne
# Browser-Upload-Detour. Komplement zu cyjan-tap update am Tap.
#
# Subkommandos:
#   cyjan-update                    Status: Ist-Version + neuestes Release
#   cyjan-update apply              Aktuelles GitHub-Release ziehen + applien
#   cyjan-update apply v2.5.10      Spezifische Version
#   cyjan-update apply --from-zip <path>  Air-Gap: ZIP vom Laptop kopiert
#
# Wird nur am Master ausgeführt (am Tap ist `cyjan-tap update --from-master`
# der Pull-Pfad). Braucht root für docker + post-update.sh — re-execed sich
# selbst per sudo wenn nötig.
set -euo pipefail

REPO="JxxKal/ids"
IDS_DIR="/opt/ids"
VERSION_FILE="$IDS_DIR/VERSION"
COMPOSE_FILE="$IDS_DIR/docker-compose.yml"
TAG="[cyjan-update]"

# Compose-Profile aus /etc/cyjan/profile (kommasepariert, z.B. "prod,snort").
# War bis v2.5.32 hartkodiert "prod" — auf prod,snort-Hosts blieben snort/
# snort-bridge dadurch nach jedem Update auf dem alten Container stehen,
# obwohl docker load die neuen Images längst eingespielt hatte.
PROFILE="$(cat /etc/cyjan/profile 2>/dev/null | tr -d '[:space:]')"
[ -z "$PROFILE" ] && PROFILE="prod"
PROFILE_ARGS=()
IFS=',' read -ra _profiles <<< "$PROFILE"
for _p in "${_profiles[@]}"; do
  [ -n "$_p" ] && PROFILE_ARGS+=(--profile "$_p")
done

# Falls /etc/environment einen Proxy hat, importieren — sonst geht curl auf
# Offline-Hosts ins Leere.
if [ -r /etc/environment ] && [ -z "${HTTPS_PROXY:-}${https_proxy:-}" ]; then
  # shellcheck disable=SC1091
  set -a; . /etc/environment; set +a
fi

have_root()      { [ "$EUID" -eq 0 ]; }
have_jq()        { command -v jq >/dev/null 2>&1; }
read_version()   { [ -r "$VERSION_FILE" ] && tr -d '[:space:]' < "$VERSION_FILE" || echo "unknown"; }

# Verifiziert die sha256-Summe einer Datei gegen einen Erwartungswert.
# Akzeptiert Hex mit/ohne 'sha256:'-Prefix, case-insensitiv. Rückgabe 0 = OK.
verify_sha256() {
  local path="$1" expected="$2" actual norm
  norm=$(printf '%s' "$expected" | grep -oiE '[0-9a-f]{64}' | head -1 | tr 'A-F' 'a-f')
  if [ -z "$norm" ]; then
    echo "$TAG FEHLER: ungültiger sha256-Erwartungswert: '$expected'" >&2
    return 1
  fi
  actual=$(sha256sum "$path" | awk '{print $1}' | tr 'A-F' 'a-f')
  if [ "$actual" != "$norm" ]; then
    echo "$TAG FEHLER: SHA256-Mismatch am Update-ZIP — Abbruch." >&2
    echo "$TAG   erwartet: $norm" >&2
    echo "$TAG   bekommen: $actual" >&2
    return 1
  fi
  echo "$TAG Integrität OK (sha256 $actual)"
  return 0
}

# Versucht den erwarteten sha256 des Release-Assets serverseitig (über TLS)
# zu ermitteln — ohne Workflow-Änderung nutzbar. Reihenfolge:
#   (a) '<asset>.sha256'-Companion-Asset (Standard-Konvention), falls angehängt
#   (b) GitHub-API: assets[].digest ('sha256:<hex>', von GitHub berechnet)
# Gibt lowercase-Hex auf stdout aus oder nichts (return 1), wenn nichts findbar.
fetch_expected_sha() {
  local tag="$1" asset="$2" url="$3" sha="" sha_txt resp digest
  # (a) Companion-Asset
  sha_txt=$(curl -fsSL --max-time 60 "${url}.sha256" 2>/dev/null || true)
  if [ -n "$sha_txt" ]; then
    sha=$(printf '%s\n' "$sha_txt" | grep -oiE '[0-9a-f]{64}' | head -1 || true)
    if [ -n "$sha" ]; then printf '%s' "$sha" | tr 'A-F' 'a-f'; return 0; fi
  fi
  # (b) GitHub-API asset.digest
  resp=$(curl -fsSL --max-time 30 -H 'Accept: application/vnd.github+json' \
              "https://api.github.com/repos/$REPO/releases/tags/$tag" 2>/dev/null || true)
  if [ -n "$resp" ]; then
    if have_jq; then
      digest=$(jq -r --arg n "$asset" '.assets[]? | select(.name==$n) | .digest // empty' <<<"$resp" 2>/dev/null | head -1)
    else
      digest=$(printf '%s' "$resp" | python3 -c '
import json,sys
try: d=json.load(sys.stdin)
except Exception: sys.exit(0)
n=sys.argv[1]
for a in d.get("assets",[]) or []:
    if a.get("name")==n and a.get("digest"):
        print(a["digest"]); break
' "$asset" 2>/dev/null || true)
    fi
    if [ -n "$digest" ]; then
      sha=$(printf '%s' "$digest" | grep -oiE '[0-9a-f]{64}' | head -1 || true)
      if [ -n "$sha" ]; then printf '%s' "$sha" | tr 'A-F' 'a-f'; return 0; fi
    fi
  fi
  return 1
}

api_latest_tag() {
  # GitHub-API: latest release tag. Liefert leer wenn offline oder rate-limited.
  local resp
  resp=$(curl -fsSL --max-time 15 \
              -H 'Accept: application/vnd.github+json' \
              "https://api.github.com/repos/$REPO/releases/latest" 2>/dev/null) || return 1
  if have_jq; then
    jq -r .tag_name <<<"$resp"
  else
    python3 -c 'import json,sys;print(json.load(sys.stdin)["tag_name"])' <<<"$resp"
  fi
}

cmd_status() {
  local cur lat
  cur=$(read_version)
  echo "Installiert:    $cur"
  if lat=$(api_latest_tag 2>/dev/null) && [ -n "$lat" ]; then
    echo "Latest GitHub:  $lat"
    if [ "$cur" = "$lat" ]; then
      echo "Status:         aktuell"
    else
      echo "Status:         Update verfügbar — 'cyjan-update apply' zum Einspielen"
    fi
  else
    echo "Latest GitHub:  (nicht erreichbar — Proxy/Internet prüfen)"
  fi
}

cmd_help() {
  cat <<EOF
$TAG Master-Console-Updater

Verwendung:
  cyjan-update                        Status (Ist-Version, neuestes Release)
  cyjan-update apply                  Latest-Release ziehen + applien
  cyjan-update apply <tag>            Spezifische Version, z.B. v2.5.10
  cyjan-update apply --from-zip PATH  Vorab kopiertes Update-ZIP (Air-Gap)

Optionen für apply:
  -y, --yes                           Ohne Rückfrage durchziehen
  --sha256 HASH                       Erwartete sha256 des Update-ZIP (Integritätsprüfung).
                                      Ohne Angabe wird der Digest — wenn verfügbar —
                                      serverseitig über TLS ermittelt und geprüft;
                                      sonst wird eine deutliche Warnung ausgegeben.
  --skip-postupdate                   post-update.sh NICHT laufen lassen
  --skip-compose                      Compose-Recreate überspringen (nur Images laden)
EOF
}

cmd_apply() {
  local target="" from_zip="" yes=0 skip_post=0 skip_compose=0 expected_sha=""
  while [ $# -gt 0 ]; do
    case "$1" in
      --from-zip)        from_zip="$2"; shift 2 ;;
      --sha256)          expected_sha="$2"; shift 2 ;;
      -y|--yes)          yes=1; shift ;;
      --skip-postupdate) skip_post=1; shift ;;
      --skip-compose)    skip_compose=1; shift ;;
      v*|V*)             target="$1"; shift ;;
      -*)                echo "$TAG Unbekannte Option: $1" >&2; exit 2 ;;
      *)                 echo "$TAG Unerwartetes Argument: $1" >&2; exit 2 ;;
    esac
  done

  if ! have_root; then
    command -v sudo >/dev/null || { echo "$TAG braucht root, sudo fehlt"; exit 1; }
    # Re-Exec-Argumente sauber als Array — quotet Pfade mit Leerzeichen korrekt
    # (früher war --from-zip "$from_zip" unquoted → Word-Splitting bei
    # Pfaden mit Spaces) und reicht --sha256 mit durch.
    local -a reexec=(apply)
    [ -n "$target" ]        && reexec+=("$target")
    [ -n "$from_zip" ]      && reexec+=(--from-zip "$from_zip")
    [ -n "$expected_sha" ]  && reexec+=(--sha256 "$expected_sha")
    [ "$yes" -eq 1 ]        && reexec+=(--yes)
    [ "$skip_post" -eq 1 ]  && reexec+=(--skip-postupdate)
    [ "$skip_compose" -eq 1 ] && reexec+=(--skip-compose)
    exec sudo -E "$0" "${reexec[@]}"
  fi

  for bin in curl unzip zstd docker sha256sum; do
    command -v "$bin" >/dev/null || { echo "$TAG benötigt $bin"; exit 1; }
  done

  local cur
  cur=$(read_version)
  echo "$TAG Ist-Version: $cur"

  local zip_path=""
  if [ -n "$from_zip" ]; then
    [ -r "$from_zip" ] || { echo "$TAG ZIP nicht lesbar: $from_zip"; exit 1; }
    zip_path="$from_zip"
    echo "$TAG ZIP aus lokalem Pfad: $zip_path"
  else
    # Latest-Tag holen wenn nichts angegeben
    if [ -z "$target" ]; then
      target=$(api_latest_tag) || { echo "$TAG Konnte Latest-Tag nicht abfragen"; exit 1; }
    fi
    echo "$TAG Ziel: $target"
    if [ "$cur" = "$target" ] && [ "$yes" -eq 0 ]; then
      read -r -p "$TAG Bereits $target installiert — trotzdem anwenden? [y/N] " a
      case "$a" in y|Y|yes) ;; *) echo "Abgebrochen."; exit 0 ;; esac
    fi
    if [ "$yes" -eq 0 ]; then
      read -r -p "$TAG Update auf $target einspielen? [y/N] " a
      case "$a" in y|Y|yes) ;; *) echo "Abgebrochen."; exit 0 ;; esac
    fi
    zip_path="/tmp/cyjan-update-${target}.zip"
    local asset_name="cyjan-ids-update-${target}.zip"
    local url="https://github.com/$REPO/releases/download/$target/${asset_name}"
    echo "$TAG Lade $url …"
    curl -fL --progress-bar --max-time 1800 -o "$zip_path" "$url"
    # Erwarteten Hash serverseitig ermitteln, falls nicht per --sha256 gesetzt.
    if [ -z "$expected_sha" ]; then
      expected_sha=$(fetch_expected_sha "$target" "$asset_name" "$url") || expected_sha=""
      [ -n "$expected_sha" ] && echo "$TAG Server-Digest gefunden — Integrität wird geprüft."
    fi
  fi

  # ── Integritätsprüfung des ZIP (vor docker load / rsync / post-update.sh) ──
  # Konsistent zum gehärteten Tap-Pfad (cyjan-tap update prüft das Bundle
  # gegen den Manifest-sha256). Ohne verifizierbaren Hash wird NICHT still
  # weitergemacht — es gibt eine deutliche Warnung, damit der Operator den
  # ungeprüften Rollout bewusst akzeptiert.
  if [ -n "$expected_sha" ]; then
    verify_sha256 "$zip_path" "$expected_sha" || exit 1
  else
    echo "$TAG ────────────────────────────────────────────────────────────" >&2
    echo "$TAG ⚠  WARNUNG: Update-ZIP wird OHNE Integritätsprüfung angewendet." >&2
    echo "$TAG    Kein --sha256 angegeben und kein serverseitiger Digest" >&2
    echo "$TAG    gefunden. Der Schutz beschränkt sich auf TLS zum Download —" >&2
    echo "$TAG    ein kompromittiertes Release/TLS-Bypass bliebe unentdeckt." >&2
    echo "$TAG    Für einen verifizierten Rollout den erwarteten Hash setzen:" >&2
    echo "$TAG      cyjan-update apply ${target:-<tag>} --sha256 <hash>" >&2
    echo "$TAG ────────────────────────────────────────────────────────────" >&2
  fi

  # ── ZIP entpacken (Sources + images.tar.zst nach /tmp) ────────────────────
  # stage bewusst NICHT local — der EXIT-Trap läuft im globalen Scope und
  # würde sonst nach Funktionsende auf eine unset-Variable greifen (set -u
  # → "stage ist nicht gesetzt"). ${stage:-} im Trap ist die zweite Bremse,
  # falls jemand das später doch auf local umstellt.
  stage=$(mktemp -d --suffix=.cyjan-update)
  trap 'rm -rf "${stage:-}"' EXIT
  echo "$TAG Entpacke nach $stage …"
  unzip -q "$zip_path" -d "$stage"
  # CI-Build legt einen Wrapper-Subdir cyjan-ids-update-<tag>/ an. Wenn
  # images.tar.zst nicht im Stage-Root liegt, suchen wir den einzigen
  # Subdir und schalten den Stage-Pfad darauf um.
  if [ ! -r "$stage/images.tar.zst" ]; then
    local inner
    inner=$(find "$stage" -mindepth 1 -maxdepth 1 -type d | head -1)
    if [ -n "$inner" ] && [ -r "$inner/images.tar.zst" ]; then
      echo "$TAG ZIP hat Wrapper-Subdir, nutze $inner"
      stage="$inner"
    else
      echo "$TAG images.tar.zst fehlt im ZIP" >&2
      exit 1
    fi
  fi

  # ── Sources nach /opt/ids syncen ──────────────────────────────────────────
  # Wenn /opt/ids ein git-Repo ist UND clean ist: bevorzugt git pull (sauberere
  # Historie). Sonst: rsync aus dem ZIP-Stage. So funktioniert beides — auf
  # einem git-getrackten Host und auf einem Air-Gap-Host, der nur ZIPs sieht.
  if [ -d "$IDS_DIR/.git" ] && git -C "$IDS_DIR" diff --quiet 2>/dev/null \
       && [ -z "$(git -C "$IDS_DIR" status --porcelain 2>/dev/null)" ]; then
    echo "$TAG /opt/ids ist clean git-Repo → git pull"
    if ! git -C "$IDS_DIR" pull --ff-only; then
      echo "$TAG WARN: git pull fast-forward fehlgeschlagen — Sources aus dem ZIP gespiegelt."
      rsync -a --delete-after \
        --exclude='.git' --exclude='.env' --exclude='.env.bak' \
        --exclude='tap-update' --exclude='geoip' \
        "$stage/" "$IDS_DIR/"
    fi
  else
    echo "$TAG /opt/ids ist kein clean git-Repo → Sources aus dem ZIP gespiegelt"
    rsync -a \
      --exclude='.git' --exclude='.env' --exclude='.env.bak' \
      --exclude='tap-update' --exclude='geoip' \
      "$stage/" "$IDS_DIR/"
  fi

  # tap-update/ wird oben bewusst aus dem allgemeinen Sync ausgeschlossen
  # (großes images-tap.tar.zst; im --delete-after-Pfad würde ein altes ZIP ohne
  # tap-update/ das Verzeichnis sonst wipen). Hier gezielt aus dem ZIP-Stage
  # nachziehen, FALLS eines dabei ist — damit der CLI-Update den Master-Push-
  # Pfad (/opt/ids/tap-update/ → master-uplink /tap-update/<file>) genauso
  # frisch hält wie das GUI-System-Update. Ohne dies serviert der Master nach
  # einem CLI-Update weiter das ALTE Tap-Bundle, und `cyjan-tap update
  # --from-master` zieht eine veraltete Version.
  if [ -d "$stage/tap-update" ]; then
    echo "$TAG tap-update/ aus ZIP nachziehen (Master-Push-Bundle aktualisieren)"
    mkdir -p "$IDS_DIR/tap-update"
    rsync -a --delete "$stage/tap-update/" "$IDS_DIR/tap-update/"
  fi

  # ── VERSION-Pinning ───────────────────────────────────────────────────────
  # Der Source-Sync oben hat VERSION bereits auf den neuen Stand gehoben. Wir
  # merken uns den Zielwert und setzen VERSION vorerst auf den ALTEN Stand
  # zurück — geschrieben wird die neue Version erst NACH erfolgreichem docker
  # load + compose up. Sonst meldet ein abgebrochener docker load (set -e) den
  # Host als bereits aktualisiert, obwohl die Images fehlen: 'cyjan-update'
  # zeigte "aktuell" und der Boot-Recreate liefe gegen nicht vorhandene Images.
  local new_ver_target
  new_ver_target=$(read_version)
  printf '%s\n' "$cur" > "$VERSION_FILE"

  # ── Images laden ─────────────────────────────────────────────────────────
  echo "$TAG Lade Images via docker load (kann je nach Bundle 1-3 min dauern) …"
  zstd -dc "$stage/images.tar.zst" | docker load

  # ── Post-Update am Host (daemon.json, systemd-Timer, etc.) ───────────────
  if [ "$skip_post" -eq 0 ] && [ -x "$IDS_DIR/scripts/post-update.sh" ]; then
    echo "$TAG Führe post-update.sh aus …"
    bash "$IDS_DIR/scripts/post-update.sh" || echo "$TAG post-update.sh hat Warnings gemeldet"
  fi

  # ── Compose recreate ─────────────────────────────────────────────────────
  if [ "$skip_compose" -eq 1 ]; then
    echo "$TAG --skip-compose gesetzt — bitte später manuell: docker compose ${PROFILE_ARGS[*]} up -d --force-recreate"
  else
    echo "$TAG docker compose ${PROFILE_ARGS[*]} up -d --force-recreate …"
    (cd "$IDS_DIR" && docker compose "${PROFILE_ARGS[@]}" up -d --force-recreate)
  fi

  # Jetzt — nach erfolgreichem docker load (+ compose up, sofern nicht
  # übersprungen) — die Ziel-Version festschreiben.
  printf '%s\n' "$new_ver_target" > "$VERSION_FILE"
  local new_ver
  new_ver=$(read_version)
  echo "$TAG Fertig. Aktive Version: $new_ver"
}

case "${1:-status}" in
  ""|status)         cmd_status ;;
  apply)             shift; cmd_apply "$@" ;;
  help|--help|-h)    cmd_help ;;
  *)                 echo "$TAG Unbekanntes Kommando: $1" >&2; cmd_help; exit 2 ;;
esac
