#!/usr/bin/env bash
# Cyjan IDS – Master-Console-Updater.
#
# Holt das aktuelle (oder ein bestimmtes) Update-ZIP aus dem GitHub-Release,
# lädt die Images via docker load und recreatet den Stack — alles ohne
# Browser-Upload-Detour. Komplement zu cyjan-tap update am Tap.
#
# Subkommandos:
#   cyjan-update                    Status: Ist-Version + neuestes Release
#   cyjan-update apply              Aktuelles GitHub-Release ziehen + applien
#   cyjan-update apply v2.5.10      Spezifische Version
#   cyjan-update apply --from-zip <path>  Air-Gap: ZIP vom Laptop kopiert
#
# Wird nur am Master ausgeführt (am Tap ist `cyjan-tap update --from-master`
# der Pull-Pfad). Braucht root für docker + post-update.sh — re-execed sich
# selbst per sudo wenn nötig.
set -euo pipefail

REPO="JxxKal/ids"
IDS_DIR="/opt/ids"
VERSION_FILE="$IDS_DIR/VERSION"
COMPOSE_FILE="$IDS_DIR/docker-compose.yml"
PROFILE="prod"
TAG="[cyjan-update]"

# Falls /etc/environment einen Proxy hat, importieren — sonst geht curl auf
# Offline-Hosts ins Leere.
if [ -r /etc/environment ] && [ -z "${HTTPS_PROXY:-}${https_proxy:-}" ]; then
  # shellcheck disable=SC1091
  set -a; . /etc/environment; set +a
fi

have_root()      { [ "$EUID" -eq 0 ]; }
have_jq()        { command -v jq >/dev/null 2>&1; }
read_version()   { [ -r "$VERSION_FILE" ] && tr -d '[:space:]' < "$VERSION_FILE" || echo "unknown"; }

api_latest_tag() {
  # GitHub-API: latest release tag. Liefert leer wenn offline oder rate-limited.
  local resp
  resp=$(curl -fsSL --max-time 15 \
              -H 'Accept: application/vnd.github+json' \
              "https://api.github.com/repos/$REPO/releases/latest" 2>/dev/null) || return 1
  if have_jq; then
    jq -r .tag_name <<<"$resp"
  else
    python3 -c 'import json,sys;print(json.load(sys.stdin)["tag_name"])' <<<"$resp"
  fi
}

cmd_status() {
  local cur lat
  cur=$(read_version)
  echo "Installiert:    $cur"
  if lat=$(api_latest_tag 2>/dev/null) && [ -n "$lat" ]; then
    echo "Latest GitHub:  $lat"
    if [ "$cur" = "$lat" ]; then
      echo "Status:         aktuell"
    else
      echo "Status:         Update verfügbar — 'cyjan-update apply' zum Einspielen"
    fi
  else
    echo "Latest GitHub:  (nicht erreichbar — Proxy/Internet prüfen)"
  fi
}

cmd_help() {
  cat <<EOF
$TAG Master-Console-Updater

Verwendung:
  cyjan-update                        Status (Ist-Version, neuestes Release)
  cyjan-update apply                  Latest-Release ziehen + applien
  cyjan-update apply <tag>            Spezifische Version, z.B. v2.5.10
  cyjan-update apply --from-zip PATH  Vorab kopiertes Update-ZIP (Air-Gap)

Optionen für apply:
  -y, --yes                           Ohne Rückfrage durchziehen
  --skip-postupdate                   post-update.sh NICHT laufen lassen
  --skip-compose                      Compose-Recreate überspringen (nur Images laden)
EOF
}

cmd_apply() {
  local target="" from_zip="" yes=0 skip_post=0 skip_compose=0
  while [ $# -gt 0 ]; do
    case "$1" in
      --from-zip)        from_zip="$2"; shift 2 ;;
      -y|--yes)          yes=1; shift ;;
      --skip-postupdate) skip_post=1; shift ;;
      --skip-compose)    skip_compose=1; shift ;;
      v*|V*)             target="$1"; shift ;;
      -*)                echo "$TAG Unbekannte Option: $1" >&2; exit 2 ;;
      *)                 echo "$TAG Unerwartetes Argument: $1" >&2; exit 2 ;;
    esac
  done

  if ! have_root; then
    command -v sudo >/dev/null || { echo "$TAG braucht root, sudo fehlt"; exit 1; }
    exec sudo -E "$0" apply ${target:+"$target"} \
         ${from_zip:+--from-zip "$from_zip"} \
         $([ "$yes" -eq 1 ] && echo --yes) \
         $([ "$skip_post" -eq 1 ] && echo --skip-postupdate) \
         $([ "$skip_compose" -eq 1 ] && echo --skip-compose)
  fi

  for bin in curl unzip zstd docker; do
    command -v "$bin" >/dev/null || { echo "$TAG benötigt $bin"; exit 1; }
  done

  local cur
  cur=$(read_version)
  echo "$TAG Ist-Version: $cur"

  local zip_path=""
  if [ -n "$from_zip" ]; then
    [ -r "$from_zip" ] || { echo "$TAG ZIP nicht lesbar: $from_zip"; exit 1; }
    zip_path="$from_zip"
    echo "$TAG ZIP aus lokalem Pfad: $zip_path"
  else
    # Latest-Tag holen wenn nichts angegeben
    if [ -z "$target" ]; then
      target=$(api_latest_tag) || { echo "$TAG Konnte Latest-Tag nicht abfragen"; exit 1; }
    fi
    echo "$TAG Ziel: $target"
    if [ "$cur" = "$target" ] && [ "$yes" -eq 0 ]; then
      read -r -p "$TAG Bereits $target installiert — trotzdem anwenden? [y/N] " a
      case "$a" in y|Y|yes) ;; *) echo "Abgebrochen."; exit 0 ;; esac
    fi
    if [ "$yes" -eq 0 ]; then
      read -r -p "$TAG Update auf $target einspielen? [y/N] " a
      case "$a" in y|Y|yes) ;; *) echo "Abgebrochen."; exit 0 ;; esac
    fi
    zip_path="/tmp/cyjan-update-${target}.zip"
    local url="https://github.com/$REPO/releases/download/$target/cyjan-ids-update-${target}.zip"
    echo "$TAG Lade $url …"
    curl -fL --progress-bar --max-time 1800 -o "$zip_path" "$url"
  fi

  # ── ZIP entpacken (Sources + images.tar.zst nach /tmp) ────────────────────
  local stage
  stage=$(mktemp -d --suffix=.cyjan-update)
  trap 'rm -rf "$stage"' EXIT
  echo "$TAG Entpacke nach $stage …"
  unzip -q "$zip_path" -d "$stage"
  # CI-Build legt einen Wrapper-Subdir cyjan-ids-update-<tag>/ an. Wenn
  # images.tar.zst nicht im Stage-Root liegt, suchen wir den einzigen
  # Subdir und schalten den Stage-Pfad darauf um.
  if [ ! -r "$stage/images.tar.zst" ]; then
    local inner
    inner=$(find "$stage" -mindepth 1 -maxdepth 1 -type d | head -1)
    if [ -n "$inner" ] && [ -r "$inner/images.tar.zst" ]; then
      echo "$TAG ZIP hat Wrapper-Subdir, nutze $inner"
      stage="$inner"
    else
      echo "$TAG images.tar.zst fehlt im ZIP" >&2
      exit 1
    fi
  fi

  # ── Sources nach /opt/ids syncen ──────────────────────────────────────────
  # Wenn /opt/ids ein git-Repo ist UND clean ist: bevorzugt git pull (sauberere
  # Historie). Sonst: rsync aus dem ZIP-Stage. So funktioniert beides — auf
  # einem git-getrackten Host und auf einem Air-Gap-Host, der nur ZIPs sieht.
  if [ -d "$IDS_DIR/.git" ] && git -C "$IDS_DIR" diff --quiet 2>/dev/null \
       && [ -z "$(git -C "$IDS_DIR" status --porcelain 2>/dev/null)" ]; then
    echo "$TAG /opt/ids ist clean git-Repo → git pull"
    if ! git -C "$IDS_DIR" pull --ff-only; then
      echo "$TAG WARN: git pull fast-forward fehlgeschlagen — Sources aus dem ZIP gespiegelt."
      rsync -a --delete-after \
        --exclude='.git' --exclude='.env' --exclude='.env.bak' \
        --exclude='tap-update' --exclude='geoip' \
        "$stage/" "$IDS_DIR/"
    fi
  else
    echo "$TAG /opt/ids ist kein clean git-Repo → Sources aus dem ZIP gespiegelt"
    rsync -a \
      --exclude='.git' --exclude='.env' --exclude='.env.bak' \
      --exclude='tap-update' --exclude='geoip' \
      "$stage/" "$IDS_DIR/"
  fi

  # ── Images laden ─────────────────────────────────────────────────────────
  echo "$TAG Lade Images via docker load (kann je nach Bundle 1-3 min dauern) …"
  zstd -dc "$stage/images.tar.zst" | docker load

  # ── Post-Update am Host (daemon.json, systemd-Timer, etc.) ───────────────
  if [ "$skip_post" -eq 0 ] && [ -x "$IDS_DIR/scripts/post-update.sh" ]; then
    echo "$TAG Führe post-update.sh aus …"
    bash "$IDS_DIR/scripts/post-update.sh" || echo "$TAG post-update.sh hat Warnings gemeldet"
  fi

  # ── Compose recreate ─────────────────────────────────────────────────────
  if [ "$skip_compose" -eq 1 ]; then
    echo "$TAG --skip-compose gesetzt — bitte später manuell: docker compose --profile $PROFILE up -d --force-recreate"
  else
    echo "$TAG docker compose --profile $PROFILE up -d --force-recreate …"
    (cd "$IDS_DIR" && docker compose --profile "$PROFILE" up -d --force-recreate)
  fi

  local new_ver
  new_ver=$(read_version)
  echo "$TAG Fertig. Aktive Version: $new_ver"
}

case "${1:-status}" in
  ""|status)         cmd_status ;;
  apply)             shift; cmd_apply "$@" ;;
  help|--help|-h)    cmd_help ;;
  *)                 echo "$TAG Unbekanntes Kommando: $1" >&2; cmd_help; exit 2 ;;
esac
