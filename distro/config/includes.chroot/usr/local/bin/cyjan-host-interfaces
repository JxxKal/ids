#!/usr/bin/env python3
"""
Schreibt /etc/cyjan/host-interfaces.json mit der aktuellen NIC-Liste des
Hosts. Wird vom systemd-Timer cyjan-host-interfaces.timer minütlich
aufgerufen. Im api-Container nur readonly gemountet — der Migrations-
Import liest hier die echten Host-NICs, weil der Container in seiner
eigenen netns lebt und /sys/class/net dort die NICs nicht sieht.

Idempotent: schreibt nur, wenn sich der Inhalt geändert hat (mtime-
freundlich, damit inotify-Watcher nicht ständig getriggert werden).
"""
from __future__ import annotations

import json
import os
import subprocess
import sys
import tempfile
import time
from pathlib import Path

OUT = Path("/etc/cyjan/host-interfaces.json")
ENV_FILE = Path("/opt/ids/.env")


def read_env_var(name: str) -> str | None:
    if not ENV_FILE.is_file():
        return None
    try:
        for line in ENV_FILE.read_text(encoding="utf-8", errors="replace").splitlines():
            if line.startswith(f"{name}="):
                val = line.split("=", 1)[1].strip().strip('"').strip("'")
                if val:
                    return val
    except OSError:
        return None
    return None


def collect_interfaces() -> list[dict]:
    """`ip -j -d link` + `ip -j addr` mergen — kein jq nötig."""
    try:
        link_raw = subprocess.run(
            ["ip", "-j", "link", "show"],
            capture_output=True, text=True, check=True, timeout=5,
        ).stdout
        addr_raw = subprocess.run(
            ["ip", "-j", "addr", "show"],
            capture_output=True, text=True, check=True, timeout=5,
        ).stdout
    except (subprocess.CalledProcessError, subprocess.TimeoutExpired, FileNotFoundError) as exc:
        print(f"[host-interfaces] ip-Kommando failed: {exc}", file=sys.stderr)
        return []

    addr_by_name: dict[str, list[str]] = {}
    try:
        for ent in json.loads(addr_raw):
            name = ent.get("ifname")
            if not name:
                continue
            addrs = [
                a["local"]
                for a in ent.get("addr_info", [])
                if a.get("family") == "inet" and a.get("local")
            ]
            addr_by_name[name] = addrs
    except (json.JSONDecodeError, KeyError):
        pass

    out = []
    try:
        for ent in json.loads(link_raw):
            name = ent.get("ifname")
            if not name or name == "lo":
                continue
            flags = ent.get("flags", [])
            out.append({
                "name":      name,
                "mac":       ent.get("address", ""),
                "operstate": ent.get("operstate", "UNKNOWN"),
                "is_up":     "UP" in flags,
                "mtu":       int(ent.get("mtu", 0) or 0),
                "addresses": addr_by_name.get(name, []),
                "kind":      ent.get("link_type", "ether"),
                "is_virtual": bool(
                    name.startswith(("docker", "br-", "veth", "cy-", "tap-", "lo"))
                    or ent.get("linkinfo", {}).get("info_kind") in ("bridge", "veth", "tun")
                ),
            })
    except (json.JSONDecodeError, KeyError) as exc:
        print(f"[host-interfaces] link-JSON parse failed: {exc}", file=sys.stderr)
        return []
    return out


def main() -> int:
    OUT.parent.mkdir(parents=True, exist_ok=True)

    payload = {
        "schema":           1,
        "generated_at":     int(time.time()),
        "hostname":         os.uname().nodename,
        "mirror_interface": read_env_var("MIRROR_INTERFACE") or read_env_var("MIRROR_IFACE"),
        "mgmt_interface":   read_env_var("MANAGEMENT_INTERFACE") or read_env_var("MGMT_INTERFACE"),
        "interfaces":       collect_interfaces(),
    }
    new = json.dumps(payload, indent=2, sort_keys=True) + "\n"

    # Idempotenz: nur schreiben wenn Inhalt anders (ohne generated_at-Vergleich
    # würde sonst jeder Lauf eine neue mtime erzeugen).
    if OUT.is_file():
        try:
            old = json.loads(OUT.read_text(encoding="utf-8"))
            old.pop("generated_at", None)
            cmp_new = {**payload}
            cmp_new.pop("generated_at", None)
            if old == cmp_new:
                return 0
        except (OSError, json.JSONDecodeError):
            pass

    # atomic write
    with tempfile.NamedTemporaryFile(
        mode="w", encoding="utf-8",
        dir=OUT.parent, prefix=".host-interfaces.", suffix=".tmp",
        delete=False,
    ) as tmp:
        tmp.write(new)
        tmp_path = Path(tmp.name)
    os.chmod(tmp_path, 0o644)
    os.replace(tmp_path, OUT)
    return 0


if __name__ == "__main__":
    sys.exit(main())
