#!/usr/bin/env bash
# cyjan-tap – CLI für den Cyjan IDS Remote-Tap.
#
# Spricht mit der lokalen tap-api (Default 127.0.0.1:8001) und mit dem
# docker compose Stack unter /opt/ids. Kein eigener Auth – die tap-api
# bindet sich an localhost.
#
# Beispiele:
#   cyjan-tap status
#   cyjan-tap load follow
#   cyjan-tap connection follow
#   cyjan-tap pair https://master.example.com:8001 abcDEF...
#   cyjan-tap test
#   cyjan-tap reconnect
#   cyjan-tap logs follow tap-uplink

set -euo pipefail

TAP_API_URL="${TAP_API_URL:-http://127.0.0.1:8001}"
COMPOSE_DIR="${CYJAN_DIR:-/opt/ids}"
COMPOSE_FILE="$COMPOSE_DIR/docker-compose.tap.yml"

require_curl()  { command -v curl  >/dev/null || { echo "curl fehlt" >&2; exit 1; }; }
# jq ist nice-to-have, aber nicht hart erforderlich – wir greifen für
# JSON-Escaping auf python3 zurück, falls jq fehlt. Output-Pretty-Printing
# fällt dann auf 'cat' zurück.
have_jq()       { command -v jq >/dev/null; }
compose() { docker compose -f "$COMPOSE_FILE" "$@"; }

api_get()  { curl -fsS "$TAP_API_URL$1"; }
api_post() { curl -fsS -H 'Content-Type: application/json' -X POST -d "$2" "$TAP_API_URL$1"; }

# JSON-String-Encode für eine Bash-Variable. Ohne externe Deps – python3 ist
# auf Debian-Basis-System immer da (Wizard-Voraussetzung), jq nicht zwingend.
json_escape() {
  python3 -c 'import json,sys; print(json.dumps(sys.argv[1]))' "$1"
}

# Pretty-Print JSON wenn jq da ist, sonst raw.
maybe_jq() {
  if have_jq; then jq .; else cat; fi
}

print_state() {
  local s
  s=$(api_get /api/state) || { echo "tap-api nicht erreichbar"; return 1; }
  if have_jq; then
    jq -r '
      def fmtts: if . == null then "–" else (now - .) | tostring + "s" end;
      "Master-URL:        \(.master_url // "–")",
      "Verbindung:        \(.connection)",
      "Letzter Connect:   \(.last_connect_at | fmtts)",
      "Letzter Send:      \(.last_send_at | fmtts)",
      "Gesendet (total):  \(.sent_total)",
      "Queue-Einträge:    \(.queue_count)",
      "Queue-Bytes:       \(.queue_bytes)",
      "Cert läuft ab:     \(.cert_expires_at // "–")",
      "Letzter Fehler:    \(.last_error // "–")"
    ' <<<"$s"
  else
    # Fallback ohne jq: kompaktes Python-Pretty-Print mit den wichtigsten
    # Feldern. Genauso lesbar, nur weniger ausgeschmückt.
    # Python-Pretty-Print ohne f-string-Tricks (Python 3.11-kompatibel,
    # Debian Bookworm hat default 3.11). JSON kommt via stdin rein.
    echo "$s" | python3 -c '
import json, sys, time
d = json.loads(sys.stdin.read())
def rel(t):
    if not t: return "–"
    return str(int(time.time()-t)) + "s"
def F(v): return v if v not in (None, "") else "–"
print("Master-URL:       ", F(d.get("master_url")))
print("Verbindung:       ", F(d.get("connection")))
print("Letzter Connect:  ", rel(d.get("last_connect_at")))
print("Letzter Send:     ", rel(d.get("last_send_at")))
print("Gesendet (total): ", d.get("sent_total", 0))
print("Queue-Einträge:   ", d.get("queue_count", 0))
print("Queue-Bytes:      ", d.get("queue_bytes", 0))
print("Cert läuft ab:    ", F(d.get("cert_expires_at")))
print("Letzter Fehler:   ", F(d.get("last_error")))
'
  fi
}

# Last-Snapshot (CPU/RAM/Disk/Mirror-Traffic/Sniffer-Drops). Bewusst in einem
# Stil gerendert, der gut neben print_state funktioniert — man sieht die
# Verbindungs-Sicht und die Lokal-Health-Sicht im selben Block.
print_load() {
  local s
  s=$(api_get /api/load) || { echo "tap-api nicht erreichbar"; return 1; }
  # Python-Renderer für beide Pfade — die Bash/jq-Variante wäre für die
  # human-readable Bps/pps-Formatierung sehr unhandlich. Python ist ohnehin
  # auf jeder Tap-Maschine vorhanden.
  echo "$s" | python3 -c '
import json, sys
d = json.loads(sys.stdin.read())
def fmt_bps(b):
    if b is None: return "–"
    for u in ("B/s","KB/s","MB/s","GB/s"):
        if b < 1024: return f"{b:6.1f} {u}"
        b /= 1024
    return f"{b:6.1f} TB/s"
def fmt_int(n):
    return "–" if n is None else f"{int(n):,}".replace(",", " ")
def fmt_pct(p):
    return "–" if p is None else f"{p:.1f} %"

print()
print("─── Last (Tap-lokal) ──────────────────────────")
# Variablen vor f-strings extrahieren — Python 3.11 (Tap-Default) erlaubt
# keine Backslash-Escapes innerhalb einer f-string-Expression.
iface = d.get("iface") or "–"
print(f"Mirror-Iface:      {iface}")
cpu = d.get("cpu_pct")
print(f"CPU-Last:          {fmt_pct(cpu)}")
m = d.get("mem") or {}
mem_used = m.get("used_mb"); mem_total = m.get("total_mb")
mem_pct  = m.get("pct")
print(f"RAM:               {mem_used or 0} / {mem_total or 0} MB ({fmt_pct(mem_pct)})")
dk = d.get("disk") or {}
disk_used = dk.get("used_gb", 0); disk_total = dk.get("total_gb", 0)
disk_pct  = dk.get("pct")
print(f"Disk (Outage-Vol): {disk_used:.1f} / {disk_total:.1f} GB ({fmt_pct(disk_pct)})")

n = d.get("net") or None
if n:
    print()
    print("Mirror-Traffic (Kernel-NIC-Ebene):")
    rx_bps = n.get("rx_bps"); tx_bps = n.get("tx_bps")
    rx_pps = n.get("rx_pps"); tx_pps = n.get("tx_pps")
    print(f"  RX: {fmt_bps(rx_bps)}  /  {fmt_int(rx_pps)} pps")
    print(f"  TX: {fmt_bps(tx_bps)}  /  {fmt_int(tx_pps)} pps")
    rx_d = n.get("rx_dropped")
    if rx_d is not None and rx_d > 0:
        print(f"  Drops (Kernel-Ring-Buffer): {fmt_int(rx_d)}")
        print( "    ↑ Mirror-NIC nimmt vom Switch keine Pakete mehr an.")
        print( "      Ursache: Hardware-/Treiber-Limit (Ring-Buffer voll).")
        print( "      Fix:     ethtool -G <iface> rx 4096, mehr RX-Queues,")
        print( "               IRQ-Affinity auf dedizierte CPUs setzen.")
else:
    print()
    print("Mirror-Traffic:    (Iface nicht lesbar — sysfs-Mount oder MIRROR_IFACE prüfen)")

sn = d.get("sniffer") or {}
print()
print("Sniffer (User-Space, AF_PACKET → Kafka):")
pps = sn.get("pps"); drop = sn.get("drop_pct")
if pps is not None:
    drop_marker = "  ← Backpressure" if (drop or 0) > 0.5 else ""
    print(f"  Aktuell:   {fmt_int(pps)} pps   drop {drop:.2f} %{drop_marker}")
cap_t = sn.get("total_captured", 0); drop_t = sn.get("total_dropped", 0); kerr = sn.get("kafka_errors", 0)
print(f"  Captured:  {fmt_int(cap_t)}")
print(f"  Dropped:   {fmt_int(drop_t)}")
if drop_t > 0:
    print( "    ↑ Kernel hat Pakete an den Sniffer-Prozess übergeben,")
    print( "      aber der konnte sie nicht verarbeiten.")
    print( "      Ursache: Sniffer-CPU am Limit oder Kafka-Producer-Queue voll")
    print( "               (nachgelagerte flow-aggregator/Kafka zu langsam).")
    print( "      Fix:     mehr CPU für Sniffer, Kafka-Producer-Buffer hoch,")
    print( "               flow-aggregator-Throughput verifizieren.")
print(f"  Kafka-Err: {fmt_int(kerr)}")
note = sn.get("note")
if note:
    print(f"  Hinweis:   {note}")

# Footer-Hinweis nur wenn irgendwo Drops sichtbar sind — sonst halten wir
# den Status sauber. Bei sichtbaren Drops nochmal explizit den Unterschied
# der zwei Stellen zusammenfassen, weil der User vermutlich gerade
# debuggt.
_kernel_drops = (n or {}).get("rx_dropped") or 0
_sniffer_drops = sn.get("total_dropped") or 0
if _kernel_drops or _sniffer_drops:
    print()
    print("ℹ Drops gibt es auf zwei Ebenen — Diagnose-Hilfe:")
    print("  • Kernel-Ring-Buffer = NIC kommt nicht hinterher (Hardware-Limit)")
    print("  • Sniffer-User-Space = CPU/Kafka-Backpressure (Software-Limit)")
    print("  Beide unabhängig → unterschiedliche Fixes (siehe oben).")
'
}

cmd_status() {
  require_curl
  print_state
  print_load || true
}

cmd_load() {
  require_curl
  case "${1:-}" in
    "")
      print_load
      ;;
    follow)
      while true; do
        clear
        echo "─── cyjan-tap load follow (Ctrl+C zum Beenden) ────────────────"
        date '+%Y-%m-%d %H:%M:%S'
        # connection-Status und Last in einem Frame — wer das hier offen
        # lässt, will beides gleichzeitig im Auge.
        print_state || echo "tap-api nicht erreichbar"
        print_load || true
        sleep 2
      done
      ;;
    *)
      echo "Usage: cyjan-tap load [follow]"; exit 2 ;;
  esac
}

cmd_connection() {
  require_curl
  case "${1:-}" in
    follow)
      while true; do
        clear
        echo "─── cyjan-tap connection follow (Ctrl+C zum Beenden) ─────────────"
        date '+%Y-%m-%d %H:%M:%S'
        echo
        print_state || echo "tap-api nicht erreichbar"
        sleep 2
      done
      ;;
    *) echo "Usage: cyjan-tap connection follow"; exit 2 ;;
  esac
}

# Akzeptiert "192.168.1.230" (oder "master.lan") und baut daraus die
# Master-API-URL. Voll-URLs wie "http://x:8001" werden 1:1 durchgereicht.
# So muss der User in der CLI dieselbe einfache Eingabe machen wie im
# Wizard (Host/IP only).
_normalize_master_url() {
  local in="$1"
  case "$in" in
    http://*|https://*) printf '%s' "$in" ;;
    *) printf 'http://%s:8001' "$in" ;;
  esac
}

cmd_pair() {
  require_curl
  local raw="${1:-}" token="${2:-}"
  if [[ -z "$raw" || -z "$token" ]]; then
    echo "Usage: cyjan-tap pair <master-host-or-url> <token>"
    echo "  Beispiel: cyjan-tap pair 192.168.1.230 v_abc123..."
    echo "  Auch erlaubt: cyjan-tap pair http://192.168.1.230:8001 v_abc..."
    exit 2
  fi
  local master; master=$(_normalize_master_url "$raw")
  local body
  body=$(printf '{"master_url":%s,"token":%s}' \
    "$(json_escape "$master")" \
    "$(json_escape "$token")")
  echo "[*] Pairing mit $master …"
  api_post /api/pair "$body" | maybe_jq
  echo "[*] tap-uplink neu starten, damit das neue Cert geladen wird …"
  compose restart tap-uplink
  echo "[+] fertig"
}

cmd_auto_pair() {
  require_curl
  local raw="${1:-}" tap_name="${2:-}"
  if [[ -z "$raw" ]]; then
    cat <<USAGE
Usage: cyjan-tap auto-pair <master-host-or-url> [tap-name]
  Beispiel: cyjan-tap auto-pair 192.168.1.81 site-a-rack-3
  Auch erlaubt: cyjan-tap auto-pair http://192.168.1.81 site-a

Token-freies Pairing — der Tap meldet sich beim Master, der Master-Admin
bestätigt die Anmeldung im Web-UI (Settings → Remote Taps → "Wartende
Anfragen"). Voraussetzung: Source-IP des Taps liegt in einem der bekannten
Netzwerke des Masters.
USAGE
    exit 2
  fi
  local master; master=$(_normalize_master_url "$raw")
  local body
  if [[ -n "$tap_name" ]]; then
    body=$(printf '{"master_url":%s,"name":%s}' \
      "$(json_escape "$master")" "$(json_escape "$tap_name")")
  else
    body=$(printf '{"master_url":%s}' "$(json_escape "$master")")
  fi
  echo "[*] Auto-Pair-Anfrage an $master ..."
  api_post /api/auto-pair-start "$body" | maybe_jq

  echo
  echo "[*] Warte auf Admin-Approval — alle 5 s pollen, Ctrl+C bricht ab."
  local i=0
  while (( i < 360 )); do  # 360 × 5 s = 30 min Timeout
    sleep 5
    local s status
    s=$(api_get /api/auto-pair-status 2>/dev/null) || { echo "  tap-api nicht erreichbar"; continue; }
    if have_jq; then
      status=$(jq -r '.status // "unknown"' <<<"$s")
    else
      status=$(echo "$s" | python3 -c 'import json,sys; print(json.load(sys.stdin).get("status","unknown"))')
    fi
    case "$status" in
      approved)
        echo
        echo "[+] APPROVED — Cert installiert."
        echo "$s" | maybe_jq
        echo
        echo "[*] tap-uplink neu starten, damit das neue Cert geladen wird ..."
        compose restart tap-uplink
        echo "[+] fertig"
        return 0
        ;;
      rejected)
        echo
        echo "[-] REJECTED vom Admin. Auto-Pair abgebrochen." >&2
        echo "$s" | maybe_jq
        return 1
        ;;
      pending)
        printf "."
        ;;
      *)
        echo "  status=$status"
        ;;
    esac
    i=$(( i + 1 ))
  done
  echo
  echo "[!] Timeout nach 30 min ohne Approval. Kein Cert installiert." >&2
  return 1
}

cmd_test() {
  require_curl
  api_post /api/test-alert '{}' | maybe_jq
}

cmd_reconnect() {
  echo "[*] Erzwinge tap-uplink-Reconnect (Container-Restart) …"
  compose restart tap-uplink
}

cmd_logs() {
  case "${1:-follow}" in
    follow) shift || true; compose logs -f --tail=100 "$@" ;;
    *)      compose logs --tail=200 "$@" ;;
  esac
}

cmd_config() {
  require_curl
  case "${1:-get}" in
    get) api_get /api/config | maybe_jq ;;
    set)
      shift
      local key="${1:-}" val="${2:-}"
      if [ -z "$key" ] || [ -z "$val" ]; then
        echo "Usage: cyjan-tap config set <key> <value>"
        echo "Aktuell unterstützte Keys: master_url"
        exit 2
      fi
      case "$key" in
        master_url|MASTER_URL)
          # Kein REST-Endpoint dafür auf der tap-api — Single-User-Maschine,
          # wir editieren direkt /opt/ids/.env und restarten den Container.
          # ws:// → wss:// automatisch upgraden, master-uplink ist mTLS-only.
          case "$val" in
            ws://*) val="wss://${val#ws://}"
                    echo "Info: ws:// → wss:// upgraded (master-uplink ist mTLS-only)" ;;
            wss://*) ;;
            *) echo "FEHLER: master_url muss mit wss:// beginnen, war '$val'"; exit 2 ;;
          esac
          local env_file="${CYJAN_DIR:-/opt/ids}/.env"
          if [ ! -w "$env_file" ] && [ "$EUID" -ne 0 ]; then
            echo "FEHLER: $env_file nicht schreibbar — als root oder via sudo aufrufen."; exit 2
          fi
          if grep -qE '^MASTER_URL=' "$env_file"; then
            sed -i "s|^MASTER_URL=.*|MASTER_URL=$val|" "$env_file"
          else
            echo "MASTER_URL=$val" >> "$env_file"
          fi
          echo "MASTER_URL in $env_file gesetzt: $val"
          echo "Restart tap-uplink, damit der neue Wert wirksam wird:"
          echo "  sudo docker compose -f ${CYJAN_DIR:-/opt/ids}/docker-compose.tap.yml restart tap-uplink"
          ;;
        *)
          echo "FEHLER: Unbekannter Key '$key'. Aktuell: master_url"; exit 2 ;;
      esac
      ;;
    *) echo "Usage: cyjan-tap config get | cyjan-tap config set <key> <value>" ; exit 2 ;;
  esac
}

usage() {
  cat <<USAGE
cyjan-tap – Remote-Tap-CLI

  cyjan-tap status                       Verbindungs- + Last-Status anzeigen
  cyjan-tap load [follow]                nur Last-Block (CPU/RAM/Disk/Traffic/Drops)
  cyjan-tap connection follow            Live-Tail des Master-Connection-Status
  cyjan-tap pair <master-host> <token>    klassisches Pairing mit Master + Token
  cyjan-tap auto-pair <master-host> [name]  token-freies Pairing — Admin bestätigt im Master-UI
  cyjan-tap test                         synthetischen Test-Alert an Master schicken
  cyjan-tap reconnect                    tap-uplink-Reconnect erzwingen
  cyjan-tap logs follow [service]        Container-Logs (Default alle)
  cyjan-tap config get                   aktuelle Konfiguration
  cyjan-tap config set master_url <url>  Master-WSS-URL ändern (wss:// erzwungen)

ENV:
  TAP_API_URL    Default http://127.0.0.1:8001
  CYJAN_DIR      Default /opt/ids
USAGE
}

case "${1:-status}" in
  status)     shift; cmd_status "$@" ;;
  load)       shift; cmd_load "$@" ;;
  connection) shift; cmd_connection "$@" ;;
  pair)       shift; cmd_pair "$@" ;;
  auto-pair)  shift; cmd_auto_pair "$@" ;;
  test)       shift; cmd_test "$@" ;;
  reconnect)  shift; cmd_reconnect ;;
  logs)       shift; cmd_logs "$@" ;;
  config)     shift; cmd_config "$@" ;;
  -h|--help|help) usage ;;
  *) usage; exit 2 ;;
esac
