#!/bin/sh
# Cyjan IDS – idempotenter docker compose up beim Boot.
#
# Hintergrund: Die Restart-Policy `unless-stopped` lässt manuell gestoppte
# Container nach einem Reboot bewusst NICHT wieder anlaufen. Dadurch konnten
# einzelne Services (z.B. nach einem `docker stop ids-api` oder einem unsauber
# beendeten Update) den nächsten Reboot nicht überleben. Außerdem zieht ein
# Hard-Power-Off Container manchmal von ihrem Compose-Netzwerk ab.
#
# Diese Unit wird beim Boot einmal aufgerufen und bringt den Compose-Stack auf
# den in /etc/cyjan/profile hinterlegten Soll-Zustand. Idempotent: bereits
# laufende Container bleiben unangetastet.
set -eu

IDS_DIR="/opt/ids"
PROFILE_FILE="/etc/cyjan/profile"

# /etc/cyjan/profile enthält ein Komma-getrenntes Profil-Set, z.B. "prod" oder
# "prod,snort". Compose interpretiert "a,b" als EINEN Profilnamen, deshalb
# müssen wir pro Profil ein eigenes --profile-Flag setzen.
PROFILE_RAW="$(cat "$PROFILE_FILE" 2>/dev/null || echo prod)"

set --
old_ifs="${IFS-}"
IFS=','
for p in $PROFILE_RAW; do
  [ -n "$p" ] && set -- "$@" --profile "$p"
done
IFS="$old_ifs"

if [ ! -d "$IDS_DIR" ]; then
  echo "cyjan-stack-up: $IDS_DIR existiert nicht – Stack-Init übersprungen." >&2
  exit 0
fi

cd "$IDS_DIR"

# Hard-Power-Off-Detektion: Wir hatten zweimal die Situation, dass nach einem
# unsauberen Reboot einzelne Container in den Daemon zurückkamen, dabei aber
# ihr Compose-Netzwerk verloren hatten (`Networks: {}` im docker inspect).
# `docker compose up -d` erkennt diesen Zustand NICHT als Konfig-Drift und
# startet die kaputten Container nur, ohne sie ans Netz zu hängen – dann
# scheitert die DNS-Auflösung von service-zu-service (kafka, timescaledb…).
#
# Lösung: vor dem normalen up -d prüfen wir alle Compose-Services auf ein
# valides Network-Attachment. Sobald einer ohne Netzwerk dasteht, machen wir
# `up -d --force-recreate`, damit alle Container frisch erzeugt werden und
# zum Netzwerk dazustoßen. Im Normalfall (sauberer Reboot) bleibt es beim
# leichten up -d.
WEDGED=0
for svc in $(docker compose "$@" ps --services 2>/dev/null); do
  cname="ids-${svc}"
  if ! docker container inspect "$cname" >/dev/null 2>&1; then
    continue                                          # Service noch nie gestartet
  fi
  nets=$(docker container inspect "$cname" --format '{{len .NetworkSettings.Networks}}' 2>/dev/null || echo 0)
  if [ "$nets" = "0" ]; then
    echo "cyjan-stack-up: $cname ohne Netz-Attachment → force-recreate"
    WEDGED=1
    break
  fi
done

if [ "$WEDGED" = "1" ]; then
  echo "cyjan-stack-up: docker compose $* up -d --force-recreate (Recovery)"
  exec docker compose "$@" up -d --force-recreate
fi

echo "cyjan-stack-up: docker compose $* up -d (aus $IDS_DIR)"
exec docker compose "$@" up -d
