#!/bin/bash
# Cyjan IDS – Maintenance-Routine.
# Räumt unbenutzte Docker-Ressourcen weg, damit /var/lib/{docker,containerd}
# nicht über die Zeit voll läuft. Wird vom systemd-Timer wöchentlich
# aufgerufen, kann aber auch manuell laufen:
#
#   sudo cyjan-maintenance               # safe (dangling images, exited
#                                         # containers, unused build-cache)
#   sudo cyjan-maintenance --aggressive  # zusätzlich tagged-aber-unused
#                                         # Images. Frei werdende Bytes
#                                         # größer, dafür Recovery aus
#                                         # einem Disk-Voll-Fall heraus
#                                         # erst nach docker pull/load.
#   sudo cyjan-maintenance --dry-run     # nur anzeigen, was räumbar wäre

set -euo pipefail

AGGRESSIVE=0
DRY_RUN=0
for arg in "$@"; do
  case "$arg" in
    --aggressive) AGGRESSIVE=1 ;;
    --dry-run)    DRY_RUN=1    ;;
    -h|--help)
      sed -n '2,18p' "$0"
      exit 0
      ;;
    *) echo "Unbekanntes Argument: $arg" >&2; exit 2 ;;
  esac
done

if [ "$(id -u)" -ne 0 ]; then
  echo "Bitte als root ausführen (sudo cyjan-maintenance)." >&2
  exit 1
fi

ts() { date +'%Y-%m-%d %H:%M:%S'; }
log() { echo "[$(ts)] $*"; }

log "Disk vorher:"
df -h / /var/lib/docker 2>/dev/null | sed 's/^/  /'
log "Docker-Ressourcen vorher:"
docker system df 2>/dev/null | sed 's/^/  /'

if [ "$DRY_RUN" -eq 1 ]; then
  log "Dry-Run: würde 'docker system prune -f' (oder -af bei --aggressive) laufen lassen."
  exit 0
fi

if [ "$AGGRESSIVE" -eq 1 ]; then
  log "Aggressiv: prune -af + builder prune -af"
  docker system prune  -af
  docker builder prune -af
else
  log "Standard: prune -f (dangling Images + exited Container + Build-Cache)"
  docker system prune  -f
  docker builder prune -f
fi

log "Disk nachher:"
df -h / /var/lib/docker 2>/dev/null | sed 's/^/  /'
log "Docker-Ressourcen nachher:"
docker system df 2>/dev/null | sed 's/^/  /'

log "Fertig."
