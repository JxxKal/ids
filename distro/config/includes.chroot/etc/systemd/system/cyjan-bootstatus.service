[Unit]
Description=Cyjan IDS Boot-Status auf TTY1 anzeigen
After=network-online.target ssh.service
Wants=network-online.target
DefaultDependencies=no

[Service]
Type=oneshot
RemainAfterExit=yes
StandardOutput=tty
TTYPath=/dev/tty1
ExecStart=/usr/local/bin/cyjan-bootstatus

[Install]
WantedBy=multi-user.target
