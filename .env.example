# ══════════════════════════════════════════════════════════════════════════════
# IDS – Environment Configuration
# Kopiere diese Datei nach .env und passe die Werte an.
#   cp .env.example .env
# ══════════════════════════════════════════════════════════════════════════════

# ── Betriebsmodus ─────────────────────────────────────────────────────────────
#
# true  = Docker Desktop / Entwicklung
#         - Ein Interface für Mirror + Management
#         - API/Dashboard auf 0.0.0.0 erreichbar
#         - traffic-generator Service aktiv
#         - Startet mit: docker compose --profile test up -d
#
# false = Produktion
#         - Separates Mirror- und Management-Interface
#         - API/Dashboard nur auf MANAGEMENT_IP erreichbar
#         - Startet mit: docker compose --profile prod up -d
#
TEST_MODE=false

# ── Interfaces (Produktion, TEST_MODE=false) ──────────────────────────────────
#
# Mirror-Interface: Spiegelport des Switches, promiscuous mode
# Nur Lesen – kein Traffic wird darüber gesendet
MIRROR_IFACE=eth1

# Management-Interface: Dashboard, API, Ping/DNS-Enrichment
MANAGEMENT_IFACE=eth0

# IP-Adresse des Management-Interface (für Port-Binding der API/Frontend Ports)
# Beispiel: 192.168.1.100
MANAGEMENT_IP=192.168.1.100

# ── Interfaces (Test Mode, TEST_MODE=true) ────────────────────────────────────
#
# Beide Rollen laufen auf demselben Interface.
# Docker Desktop: meist eth0 innerhalb der Linux-VM
# MANAGEMENT_IP wird ignoriert (0.0.0.0 wird verwendet)
TEST_IFACE=eth0

# ── Packet Capture ────────────────────────────────────────────────────────────
#
# Bytes pro Paket die erfasst werden (nur Header, kein Payload)
# Empfehlung: 128 Byte reicht für Ethernet+IP+TCP/UDP Header inkl. Optionen
CAPTURE_SNAPLEN=128

# AF_PACKET Ring-Buffer Größe in MB (Prod: 64+, Test: 16 reicht)
CAPTURE_RING_BUFFER_MB=64

# ── Datenbank (TimescaleDB / PostgreSQL) ──────────────────────────────────────
#
# Passwort für den 'ids' Datenbankbenutzer
# Mindestens 16 Zeichen, keine Sonderzeichen die DSN-Parsing stören
POSTGRES_PASSWORD=ids-change-me-min16chars

# ── Object Storage (MinIO) ────────────────────────────────────────────────────
#
# Zugangsdaten für MinIO (PCAP-Header Speicher)
# Mindestens 3 Zeichen für Access Key, 8 für Secret Key
MINIO_ACCESS_KEY=ids-access
MINIO_SECRET_KEY=ids-secret-change-me

# ── API ───────────────────────────────────────────────────────────────────────
#
# Secret Key für JWT / Session Signing – in Produktion unbedingt ändern!
# Empfehlung: openssl rand -hex 32
API_SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32

# ── Flow Aggregation ──────────────────────────────────────────────────────────
#
# Flow wird beendet nach X Sekunden ohne neue Pakete (Inaktivitäts-Timeout)
FLOW_TIMEOUT_S=30

# Maximale Flow-Dauer in Sekunden (verhindert ewig offene Flows)
FLOW_MAX_DURATION_S=300

# ── Alert Manager ─────────────────────────────────────────────────────────────
#
# Deduplication: gleiche Source-IP + gleiche Regel innerhalb X Sekunden = 1 Alert
DEDUP_WINDOW_S=300

# Self-Traffic-Filter: Alerts wo die Appliance selbst src ODER dst ist werden
# verworfen (eigene DNS-Lookups, Updates, enrichment-Pings, SSH etc. sind
# kein Security-Event). Default setzt MANAGEMENT_IP + Docker-Bridge + Loopback.
# Format: kommagetrennt, akzeptiert IPs und CIDR-Blöcke.
# Leer lassen um den Filter komplett zu deaktivieren.
# IDS_SELF_IPS=192.168.1.230,172.28.0.0/16,127.0.0.0/8

# Adaptive ML-Suppression (siehe docs/ML_ENGINE.md §7)
# Baseline-Fenster in Tagen, Min-Stunden für gelernte Muster, z-Score-Schwelle
SUPPRESSION_LEARN_WINDOW_D=14
SUPPRESSION_MIN_HOURS=24
SUPPRESSION_Z_THRESHOLD=2.0

# ── Enrichment Service ────────────────────────────────────────────────────────
#
# Timeout für ICMP Ping in Millisekunden
PING_TIMEOUT_MS=1000

# Timeout für DNS-Lookup in Millisekunden
DNS_TIMEOUT_MS=2000

# Cache-TTL für angereicherte IP-Informationen in Sekunden (Standard: 1h)
CACHE_TTL_S=3600

# ── PCAP Store ────────────────────────────────────────────────────────────────
#
# Zeitfenster in Sekunden: Bei einem Alert werden Pakete ±PCAP_WINDOW_S
# um den Alert-Timestamp als Header-PCAP gespeichert
PCAP_WINDOW_S=60

# Retention für PCAP-Files in MinIO (Tage). MinIO Lifecycle-Rule räumt
# danach automatisch auf. pcap-store schreibt typisch 10–20 GB pro Tag —
# bei 7 Tagen Retention sind das ~140 GB stable state. Wer mehr Disk hat,
# kann hochsetzen; wer weniger hat (z.B. 100 GB Volume), auf 3–4 reduzieren.
# Greift beim nächsten Stack-Restart (minio-init ist idempotent).
PCAP_RETENTION_DAYS=7
# Retention für temporäre CSV-Exporte (Settings → Reports). Klein, sicher.
EXPORTS_RETENTION_DAYS=7

# ── ML / Training ─────────────────────────────────────────────────────────────
#
# Intervall für nächtliches Batch-Retrain in Sekunden (Standard: 24h)
RETRAIN_INTERVAL_S=86400

# ── Snort Integration (optional) ──────────────────────────────────────────────
#
# Aktivierung:
#   Produktion: docker compose --profile prod --profile snort up -d
#   Test:       docker compose --profile test --profile snort-test up -d
#
# Regelsets:
#   community         Snort 3 Community Rules (snort.org, kostenlos, ~4.000 Signaturen)
#   emerging-threats  ET Open Rules (emergingthreats.net, Snort 2.9 Format, ~40.000 Signaturen)
#   both              Beide Regelsets gleichzeitig laden
SNORT_RULESET=community

# true = Regelfiles beim Container-Start neu herunterladen (z.B. für Updates)
SNORT_UPDATE_RULES=false

# ── MQTT-Bridge (optional, V1) ────────────────────────────────────────────────
#
# Outbound-Publisher zu externem MQTT-Broker (Mosquitto/HiveMQ/AWS IoT).
# Default deaktiviert. Wenn aktiviert: konsumiert alerts-enriched-Topic aus
# Master-Kafka und publiziert pro Alert + alle 30s retained State-Topics.
#
# Topic-Schema (Per-Origin-Identity):
#   {prefix}/{host}/alerts/{severity}/{source}    Events (kein retain)
#   {prefix}/{host}/threat                         State (retain)
#   {prefix}/{host}/status                         online|offline (LWT, retain)
#   {prefix}/{host}/taps/{tap_name}/status         pro Tap (retain)
#
MQTT_ENABLED=false
MQTT_BROKER_HOST=mosquitto.example.com
MQTT_BROKER_PORT=8883
MQTT_USE_TLS=true
MQTT_TLS_VERIFY=true
MQTT_USERNAME=cyjan
MQTT_PASSWORD=
# Optional — sonst auto-generated als cyjan-<MQTT_MASTER_HOST_ID>
MQTT_CLIENT_ID=
# Master-Host-Identity für Per-Origin-Topic. Default: HOSTNAME des Containers
# oder "master". Für lesbare HMI-Anzeigen empfohlen, z.B. "master-hq".
MQTT_MASTER_HOST_ID=
# Topic-Prefix — kann an Plant-Konvention angepasst werden, Default "cyjan".
# Beispiel: "factory1/security" → factory1/security/<host>/alerts/...
MQTT_TOPIC_PREFIX=cyjan
# QoS: 0 (fire-and-forget) oder 1 (at-least-once). Events default 1, State 0.
MQTT_QOS_EVENTS=1
MQTT_QOS_STATE=0
# Rate-Limit beim Replay nach Reconnect, Inflight-Window für QoS-1-PUBACK
MQTT_RATE_LIMIT_PER_SEC=200
MQTT_INFLIGHT_MAX=10
# State-Topic-Frequenz (in Sekunden)
MQTT_THREAT_INTERVAL_S=30
MQTT_TAP_INTERVAL_S=30
# Cyjan-side Filter (soft-cap, Default = alles durch). Subscriber kann
# zusätzlich client-side via Topic-Wildcard filtern.
MQTT_SEVERITY_MIN=low                                       # low|medium|high|critical
MQTT_SOURCES=signature,ml,suricata,external                 # comma-sep
MQTT_RULE_ID_BLOCKLIST=                                     # z.B. "ASSET::*,UNKNOWN_HOST_001"

# ─── Lab-Modus / Pattern-Federation (NICHT am Customer-System!) ───────
# Aktiviert RedTeam-Tooling + Pattern-Export-API. Customer-Installationen
# bleiben strict auf "false". Lab-Engineer setzt true + Compose-Profil
# `redteam` UND aktiviert in Settings → System → Features die Schalter.
REDTEAM_ENABLED=false
CYJAN_LAB_ID=                              # z.B. "cyjan-lab-jxxk"
# PGP-Privkey-Passphrase für Bundle-Signing (sofern Privkey passphrase-protected).
# Production: aus HSM/Vault; Lab-Setup: hier setzen oder via Docker-Secret.
PATTERN_SIGNING_PASSPHRASE=

